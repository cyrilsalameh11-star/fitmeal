{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/public/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*\\.html$)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/reels/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
    },
    {
      "source": "/news/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
    },
    {
      "source": "/hifi/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
    },
    {
      "source": "/logos/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/admin.html",
      "dest": "/src/public/admin.html"
    },
    {
      "src": "/reels/(.*)",
      "dest": "/src/public/reels/$1",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/news/(.*)",
      "dest": "/src/public/news/$1",
      "headers": { "Cache-Control": "public, max-age=2592000" }
    },
    {
      "src": "/hifi/(.*)",
      "dest": "/src/public/hifi/$1",
      "headers": { "Cache-Control": "public, max-age=2592000" }
    },
    {
      "src": "/logos/(.*)",
      "dest": "/src/public/logos/$1",
      "headers": { "Cache-Control": "public, max-age=2592000" }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/src/public/assets/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*\\.(js|css|png|svg|ico|jpg|jpeg|gif|webp|woff|woff2|ttf|eot|json|mp4|webm|mov|m4v)$)",
      "dest": "/src/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-news",
      "schedule": "0 21 * * 6"
    }
  ]
}
