{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/server.js"
    },
    {
      "src": "/admin.html",
      "dest": "/src/public/admin.html"
    },
    {
      "src": "/(.*\\.(js|css|png|svg|ico|jpg|jpeg|gif|webp|woff|woff2|ttf|eot|json)$)",
      "dest": "/src/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-news",
      "schedule": "0 21 * * 6"
    }
  ]
}
